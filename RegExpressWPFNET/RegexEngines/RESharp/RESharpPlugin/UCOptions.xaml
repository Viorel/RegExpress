<UserControl x:Class="RESharpPlugin.UCOptions"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RESharpPlugin"
             xmlns:ui="clr-namespace:RegExpressLibrary.UI;assembly=RegExpressLibrary"
             mc:Ignorable="d" 
             Loaded="UserControl_Loaded" d:DesignHeight="124.575" d:DesignWidth="484.47" >

    <UserControl.Resources>
        <Style TargetType="ui:CheckboxWithNote">
            <EventSetter Event="Changed" Handler="CheckBox_Changed"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel>
            <StackPanel>
                <ui:CheckboxWithNote Prop="IgnoreCase" Note="Case-insensitive matching"/>
                <ui:CheckboxWithNote Prop="UseDotnetUnicode" Note="Full .NET unicode (Kelvin K, Turkish I, etc.)"/>
                <ui:CheckboxWithNote Prop="MinimizePattern" Note="Minimize alternations at the cost of build time"/>
                <ui:CheckboxWithNote Prop="FindLookaroundPrefix" Note="Optimize lookaround prefixes (expensive with unbounded)"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
    
