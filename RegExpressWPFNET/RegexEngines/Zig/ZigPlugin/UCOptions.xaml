<UserControl x:Class="ZigPlugin.UCOptions"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ZigPlugin"
             xmlns:ui="clr-namespace:RegExpressLibrary.UI;assembly=RegExpressLibrary"
             mc:Ignorable="d" 
             d:DesignHeight="119.1" d:DesignWidth="402.442" 
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <local:Versions x:Key="versions"/>
        <Style TargetType="ui:CheckboxWithNote">
            <EventSetter Event="Changed" Handler="CheckBox_Changed"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel>
            <Grid Margin="0 0 0 4">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                </Grid.LayoutTransform>
                <Grid.Resources>
                    <Style TargetType="Label">
                        <Setter Property="Padding" Value="0 2 4 2"/>
                    </Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="MinWidth" Value="120"/>
                        <Setter Property="Margin" Value="3 0 0 2"/>
                    </Style>
                </Grid.Resources>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Label Grid.Column="0" Grid.Row="0" Content="Library:" Target="{Binding ElementName=cbxLibrary}" />
                <ComboBox x:Name="cbxLibrary" Grid.Column="1" Grid.Row="0" SelectedValuePath="Tag" SelectedValue="{Binding Library, FallbackValue='ZigRegex'}" SelectionChanged="cbxLibrary_SelectionChanged">
                    <ui:ComboBoxItemWithVersion Tag="ZigRegex" Text="zig-regex" Version="{Binding ZigRegex, Source={StaticResource versions}}" IsSelected="True" />
                    <ui:ComboBoxItemWithVersion Tag="Mvzr"     Text="mvzr"      Version="{Binding Mvzr, Source={StaticResource versions}}" />
                    <ui:ComboBoxItemWithVersion Tag="Pzre"     Text="PZRE"      Version="{Binding Pzre, Source={StaticResource versions}}" />
                </ComboBox>

            </Grid>

            <StackPanel x:Name="pnlZigRegexOptions">
                <ui:CheckboxWithNote Prop="case_insensitive" Note="Matches both uppercase and lowercase letters"/>
                <ui:CheckboxWithNote Prop="multiline" Note="Not yet implemented"/>
                <ui:CheckboxWithNote Prop="dot_all" Note="Not yet implemented"/>
                <ui:CheckboxWithNote Prop="extended" Note="Not yet implemented"/>
                <ui:CheckboxWithNote Prop="unicode" Note="Not yet implemented"/>
            </StackPanel>

            <StackPanel x:Name="pnlMvzrOptions">
            </StackPanel>

            <StackPanel x:Name="pnlPzreOptions">
            </StackPanel>

        </StackPanel>

    </Grid>
</UserControl>
